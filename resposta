<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabela População Brasileira 2024</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            display: flex;
            justify-content: center;
            padding: 50px 0;
            background-color: white;
        }

        table {
            width: 950px;
            border-collapse: collapse;
            border: 1px solid black;
        }

        th, td {
            border: 1px solid black;
            padding: 4px 10px;
            font-size: 14px;
        }

        /* Cabeçalho Superior */
        .header-top {
            background-color: #d3d3d3;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            height: 40px;
            font-family: 'Times New Roman';
        }

        /* Cabeçalho das Colunas */
        .header-cols {
            background-color: #f2f2f2;
            text-align: left;
            font-weight: bold;
            font-family: 'Times New Roman';

        }

        /* Coluna de População Centralizada */
        .col-pop {
            text-align: center;
            width: 160px;
        }

        /* Maranhão: Fonte Monoespaçada */
        .font-maranhao {
            font-family: "Courier New", Courier, monospace;
        }

        /* Mato Grosso: Preservação de espaços (tag pre) */
        .font-mato-grosso {
            white-space: pre;
            font-family: Arial, Helvetica, sans-serif;
        }

        /* Rio de Janeiro: Espaçamento e recuo */
        .rio-cell {
            height: 100px;
            vertical-align: middle;
            padding-left: 60px;
        }

        .bloco-cell {
            text-align: center;
            vertical-align: middle;
        }

        /* Rodapé */
        tfoot td {
            background-color: #a9a9a9;
            font-weight: bold;
            font-family: 'Times New Roman';

        }

        mark {
            background-color: yellow;
            color: black;
        }

        .sigla {
            border-bottom: 1px dotted black;
            line-height: 1;
        }
    </style>
</head>
<body>

<table>
    <thead>
        <tr>
            <th colspan="3" class="header-top">População dos Estados Brasileiros - 2024</th>
        </tr>
        <tr class="header-cols">
            <th style="width: 35%;">Estado</th>
            <th class="col-pop">População</th>
            <th style="width: 45%;">Comando HTML Utilizado</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td><b>Acre</b></td>
            <td class="col-pop"><b><mark>830.018</mark></b></td>
            <td>`<b>Negrito</b>` e `<mark>Destacado</mark>`</td>
        </tr>
        <tr>
            <td><i>Alagoas</i></td>
            <td class="col-pop">3.365.351</td>
            <td>`<i>Itálico</i>`</td>
        </tr>
        <tr>
            <td><u>Amapá</u></td>
            <td class="col-pop">877.613</td>
            <td>`<u>Texto sublinhado</u>`</td>
        </tr>
        <tr>
            <td><s><u>Amazonas</u></u></td>
            <td class="col-pop"><u>4.269.995</u></td>
            <td>`<s>Texto riscado</s>` e `<u>Texto sublinhado</u>`</td>
        </tr>
        <tr>
            <td>Bahia</td>
            <td class="col-pop">14.141.626</td>
            <td>-Texto <sup>sobrescrito</sup>-</td>
        </tr>
        <tr>
            <td><span class="sigla">CE</span></td>
            <td class="col-pop">9.240.580</td>
            <td>`Abreviação`</td>
        </tr>
        <tr>
            <td><b>Distrito Federal</b></td>
            <td class="col-pop">3.098.883</td>
            <td>`Texto em negrito`</td>
        </tr>
        <tr>
            <td>“Espírito Santo”</td>
            <td class="col-pop">4.108.508</td>
            <td>`“Citação curta”`</td>
        </tr>
        <tr>
            <td><i>Goiás</i></td>
            <td class="col-pop">7.206.589</td>
            <td>`<i>Citação de fonte</i>`</td>
        </tr>
        <tr>
            <td class="font-maranhao">Maranhão</td>
            <td class="col-pop">6.775.805</td>
            <td>`Texto monoespaçado`</td>
        </tr>
        <tr style="height: 100px;">
            <td class="font-mato-grosso">
Mato Grosso</td>
            <td class="col-pop">3.658.813</td>
            <td>. <br> Texto pré-formatado <br> .</td>
        </tr>
        <tr>
            <td><small>Paraíba</small></td>
            <td class="col-pop">4.059.905</td>
            <td>`Texto pequeno`</td>
        </tr>
        <tr>
            <td>Piauí</td>
            <td class="col-pop">3.281.480</td>
            <td>Texto <sub>subscrito</sub></td>
        </tr>
        <tr>
            <td class="rio-cell">Rio de Janeiro</td>
            <td class="col-pop">16.054.524</td>
            <td class="bloco-cell">. <br> Citação em bloco <br> .</td>
        </tr>
        <tr>
            <td><b>Rio Grande do Sul</b></td>
            <td class="col-pop">10.882.965</td>
            <td>`Negrito`</td>
        </tr>
        <tr>
            <td><i>Rondônia</i></td>
            <td class="col-pop">1.616.379</td>
            <td>`Itálico`</td>
        </tr>
        <tr>
            <td><mark>Roraima</mark></td>
            <td class="col-pop">636.707</td>
            <td><mark>`Texto destacado`</mark></td>
        </tr>
        <tr>
            <td><span class="sigla">TO</span></td>
            <td class="col-pop">1.607.363</td>
            <td>`Abreviação`</td>
        </tr>
    </tbody>
    <tfoot>
        <tr>
            <td><b>Total da população estimada:</b></td>
            <td class="col-pop">Soma total</td>
            <td>Realizar a soma das colunas</td>
        </tr>
    </tfoot>
</table>

</body>
</html>
