<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabela População Brasileira 2024</title>
    <style>
        body {
            font-family: 'Times New Roman';
            display: flex;
            justify-content: center;
            padding: 50px 0;
            background-color: white;
        }

        table {
            width: 950px;
            border-collapse: collapse;
            border: 1px solid black;
        }

        th,
        td {
            border: 1px solid black;
            padding: 4px 10px;
            font-size: 14px;
        }


        .header-top {
            background-color: #d3d3d3;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            height: 40px;
            font-family: 'Times New Roman';
        }


        .header-cols {
            background-color: #f2f2f2;
            text-align: left;
            font-weight: bold;
            font-family: 'Times New Roman';
        }


        .col-pop {
            text-align: right;
            width: 160px;
        }


        .font-maranhao {
            font-family: 'Times New Roman';
        }


        .font-mato-grosso {
            white-space: pre;
            font-family: 'Times New Roman';
            text-align: left;
        }


        .rio-cell {
            height: 100px;
            vertical-align: middle;
            padding-left: 60px;
        }

        .bloco-cell {
            text-align: left;
            vertical-align: middle;
        }


        tfoot td {
            background-color: #a9a9a9;
            font-weight: bold;
            font-family: 'Times New Roman';
        }

        mark {
            background-color: yellow;
            color: black;
        }

        .sigla {
            border-bottom: 1px dotted black;
            line-height: 1;
        }


        pre {
            font-family: 'Times New Roman', serif;
            margin: 0;
            display: inline;
        }
    </style>
</head>

<body>

    <table>
        <thead>
            <tr>
                <th colspan="3" class="header-top">População dos Estados Brasileiros - 2024</th>
            </tr>
            <tr class="header-cols">
                <th style="width: 35%;">Estado</th>
                <th class="col-pop">População</th>
                <th style="width: 45%;">Comando HTML Utilizado</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><strong>Acre</strong></td>
                <td class="col-pop"><strong><mark>830.018</mark></strong></td>
                <td>`<strong>Negrito</strong>` e `<mark>Destacado</mark>`</td>
            </tr>
            <tr>
                <td><em>Alagoas</em></td>
                <td class="col-pop">3.365.351</td>
                <td>`<em>Itálico</em>`</td>
            </tr>
            <tr>
                <td><u>Amapá</u></td>
                <td class="col-pop">877.613</td>
                <td><u>Texto sublinhado</u></td>
            </tr>
            <tr>
                <td><s><u>Amazonas</u></s></td>
                <td class="col-pop"><u>4.269.995</u></td>
                <td>`<s>Texto riscado</s>` e `<u>Texto sublinhado</u>`</td>
            </tr>
            <tr>
                <td>Bahia</td>
                <td class="col-pop">14.141.626</td>
                <td>-Texto <sup>sobrescrito</sup>-</td>
            </tr>
            <tr>
                <td><abbr title="CEARÁ" class="sigla">CE</abbr></td>
                <td class="col-pop">9.240.580</td>
                <td>`Abreviação`</td>
            </tr>
            <tr>
                <td><strong>Distrito Federal</strong></td>
                <td class="col-pop">3.098.883</td>
                <td><strong>'Texto em negrito'</strong></td>
            </tr>
            <tr>
                <td><q>Espírito Santo</q></td>
                <td class="col-pop">4.108.508</td>
                <td><q>Citação curta</q></td>
            </tr>
            <tr>
                <td><cite>Goiás</cite></td>
                <td class="col-pop">7.206.589</td>
                <td><cite>'Citação de fonte'</cite></td>
            </tr>
            <tr>
                <td><code>Maranhão</code></td>
                <td class="col-pop">6.775.805</td>
                <td><code>'Texto monoespaçado'</code></td>
            </tr>
            <tr style="height: 100px;">
                <td class="font-mato-grosso">
                    <pre>Mato Grosso</pre>
                </td>
                <td class="col-pop">3.658.813</td>
                <td>. <br>
                    <pre>Texto pré-formatado</pre> <br> .
                </td>
            </tr>
            <tr>
                <td><small>Paraíba</small></td>
                <td class="col-pop">4.059.905</td>
                <td><small>'Texto pequeno'</small></td>
            </tr>
            <tr>
                <td>Piauí</td>
                <td class="col-pop">3.281.480</td>
                <td>'Texto <sub>subscrito</sub>'</td>
            </tr>
            <tr>
                <td class="rio-cell">
                    <blockquote>Rio de Janeiro</blockquote>
                </td>
                <td class="col-pop">16.054.524</td>
                <td class="bloco-cell">. <br>
                    <blockquote>Citação em bloco</blockquote> <br> .
                </td>
            </tr>
            <tr>
                <td><strong>Rio Grande do Sul</strong></td>
                <td class="col-pop">10.882.965</td>
                <td> <strong>'Negrito'</strong></td>
            </tr>
            <tr>
                <td><em>Rondônia</em></td>
                <td class="col-pop">1.616.379</td>
                <td><em>'Itálico'</em></td>
            </tr>
            <tr>

                <td><mark>Roraima</mark></td>
                <td class="col-pop">636.707</td>
                <td><mark>`Texto destacado`</mark></td>
            </tr>
            <tr>
                <td><abbr title="TOCANTINS" class="sigla">TO</abbr></td>
                <td class="col-pop">1.607.363</td>
                <td>`Abreviação`</td>
            </tr>
        </tbody>
        <tfoot>
            <tr>
                <td><b>Total da população estimada:</b></td>
                <td class="col-pop">97.713.104</td>
                <td>Realizar a soma das colunas</td>
            </tr>
        </tfoot>
    </table>

</body>

</html>
